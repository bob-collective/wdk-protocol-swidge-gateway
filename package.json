{
  "name": "@gobob/wdk-protocol-swidge-gateway",
  "version": "0.0.1",
  "description": "BOB Gateway swidge module for the Tether Wallet Development Kit — native BTC ⇄ token routes.",
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bare": "./bare.js",
      "default": "./dist/index.js"
    },
    "./package": "./package.json"
  },
  "files": ["dist", "bare.js"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@tetherto/wdk-wallet": "1.0.0-beta.12",
    "bitcoinjs-lib": "6.1.7",
    "ethers": "^6",
    "tronweb": "^6",
    "bare-node-runtime": "*"
  },
  "peerDependencies": {
    "@tetherto/wdk-wallet-btc": "1.0.0-beta.10",
    "@tetherto/wdk-wallet-evm": "1.0.0-beta.14",
    "@tetherto/wdk-wallet-evm-erc-4337": "1.0.0-beta.10"
  },
  "devDependencies": {
    "@tetherto/wdk-wallet-btc": "1.0.0-beta.10",
    "@tetherto/wdk-wallet-evm": "1.0.0-beta.14",
    "@tetherto/wdk-wallet-evm-erc-4337": "1.0.0-beta.10",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "prettier": "^3",
    "typescript": "^5",
    "vitest": "^2"
  },
  "license": "Apache-2.0"
}
